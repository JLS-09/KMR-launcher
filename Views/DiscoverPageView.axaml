<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             mc:Ignorable="d" d:DesignWidth="1144" d:DesignHeight="720"
             xmlns:vm="clr-namespace:KMRLauncherMvvm.ViewModels"
             x:DataType="vm:DiscoverPageViewModel"
             x:Class="KMRLauncherMvvm.Views.DiscoverPageView"
             Background="{DynamicResource PrimaryBackground}"
             Foreground="{DynamicResource PrimaryText}">

    <Design.DataContext>
        <vm:DiscoverPageViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="TextBox">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="#1F1F20" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style Selector="TextBox:pointerover /template/ Border">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="#1F1F20" />
        </Style>

        <Style Selector="TextBox:focus /template/ Border">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="#1F1F20" />
        </Style>
        
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <Style Selector="Button:focus /template/ ContentPresenter">
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        
        <Style Selector="Button.ButtonRefresh:pointerover /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
        </Style>
        
        <Style Selector="Button.ButtonRefresh:focus /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBlue}"/>
        </Style>
        
        <Style Selector="Button.ButtonApply:pointerover /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryGreen}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryGreen}"/>
        </Style>
        
        <Style Selector="Button.ButtonApply:focus /template/ ContentPresenter">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryGreen}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryGreen}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto Auto Auto *" Margin="32 16" RowSpacing="24">
        <Grid Grid.Row="0" ColumnDefinitions="*, auto" RowDefinitions="*, auto" ColumnSpacing="32">
            <ProgressBar Grid.Column="0" Grid.Row="0" Height="21"
                         ShowProgressText="{Binding !LoadProgress.IsCache}" 
                         Foreground="{DynamicResource PrimaryRed}" CornerRadius="0" 
                         Value="{Binding LoadProgress.ModsReceived}"
                         Maximum="{Binding LoadProgress.TotalMods}" 
                         IsVisible="{Binding IsLoading}"
                         IsIndeterminate="{Binding LoadProgress.IsCache}"/>
            <TextBlock Grid.Column="0" Grid.Row="1"
                       VerticalAlignment="Center" HorizontalAlignment="Left"
                       Text="{Binding LoadProgress.CurrentModName}"
                       FontFamily="{DynamicResource SpaceGrotesk}" FontWeight="Regular" FontSize="14"
                       LetterSpacing="1.4" Foreground="{DynamicResource SecondaryText}"
                       IsVisible="{Binding IsLoading}"/>
            <TextBlock Grid.Column="0" Grid.Row="0"
                       Text="{Binding ConnectionStatus}"
                       FontFamily="{DynamicResource SpaceGrotesk}" FontWeight="Regular" FontSize="16"
                       LetterSpacing="1.4" Foreground="{DynamicResource SecondaryText}"
                       IsVisible="{Binding !IsLoading}"/>
            <TextBlock Grid.Column="1" Grid.Row="0"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Text="NETWORK STATUS"
                       FontFamily="{DynamicResource SpaceGrotesk}"
                       FontWeight="Regular"
                       FontSize="14"
                       LetterSpacing="1.4"
                       Foreground="{DynamicResource SecondaryText}" />
            <TextBlock Grid.Column="1" Grid.Row="1"
                       VerticalAlignment="Center" HorizontalAlignment="Right"
                       Text="NETWORK_SYNCHRONIZED"
                       FontFamily="{DynamicResource SpaceGrotesk}"
                       FontWeight="Bold"
                       FontSize="16"
                       LetterSpacing="1.4"
                       Foreground="{DynamicResource PrimaryGreen}" />
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="* * * * *" ColumnSpacing="4">
            <TextBox Grid.Column="0" PlaceholderText="MOD NAME..." FontFamily="{DynamicResource SpaceGrotesk}"
                     Text="{Binding ModFilter}">
                <TextBox.InnerLeftContent>
                    <Label Classes="iconBold" FontWeight="Regular" Content="&#xE30C;" FontSize="18"
                           Foreground="{DynamicResource SecondaryText}" Padding="16 0 0 0" />
                </TextBox.InnerLeftContent>
            </TextBox>
            <TextBox Grid.Column="1" PlaceholderText="AUTHOR..." FontFamily="{DynamicResource SpaceGrotesk}"
                     Text="{Binding AuthorFilter}">
                <TextBox.InnerLeftContent>
                    <Label Classes="iconBold" FontWeight="Regular" Content="&#xE4C2;" FontSize="20"
                           Foreground="{DynamicResource SecondaryText}" Padding="16 0 0 0" />
                </TextBox.InnerLeftContent>
            </TextBox>
            <TextBox Grid.Column="2" />
            <Button Grid.Column="3" Classes="ButtonRefresh" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="0"
                    BorderThickness="1" BorderBrush="{DynamicResource PrimaryBlue}" 
                    Foreground="{DynamicResource PrimaryBlue}" Background="#002D52"
                    FontSize="20" FontFamily="{DynamicResource SpaceGrotesk}" HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center" Command="{Binding FetchModsCommand}"
                    CommandParameter="{Binding IsEnabledFlag}">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Label Classes="icon" FontWeight="Regular" Content="&#xE094;" FontSize="24" />
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="4" Classes="ButtonApply" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="0"
                    BorderThickness="1" BorderBrush="{DynamicResource PrimaryGreen}"
                    Foreground="{DynamicResource PrimaryGreen}" Background="#033A16"
                    FontSize="20" FontFamily="{DynamicResource SpaceGrotesk}" HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Label Classes="icon" FontWeight="Regular" Content="&#xE53A;" FontSize="24" />
                    <TextBlock Text="Apply" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
        <Grid Grid.Row="2" ColumnDefinitions="4*, 1.5*, *, 0.75*" Margin="0 16 24 16" ColumnSpacing="8">
            <TextBlock Grid.Column="0" Text="MOD_NAME" Foreground="{DynamicResource SecondaryText}"
                       FontSize="13" FontFamily="{DynamicResource SpaceGrotesk}" FontWeight="Bold" />
            <TextBlock Grid.Column="1" Text="AUTHOR(S)" Foreground="{DynamicResource SecondaryText}"
                       FontSize="13" FontFamily="{DynamicResource SpaceGrotesk}" FontWeight="Bold" />
            <TextBlock Grid.Column="2" Text="VERSION" Foreground="{DynamicResource SecondaryText}"
                       FontSize="13" FontFamily="{DynamicResource SpaceGrotesk}" FontWeight="Bold" />
            <TextBlock Grid.Column="3" Text="LAST_UPDATE" Foreground="{DynamicResource SecondaryText}"
                       FontSize="13" FontFamily="{DynamicResource SpaceGrotesk}" FontWeight="Bold" />
        </Grid>
        <ListBox ItemsSource="{Binding ModListFiltered}"
                 Background="Transparent" Grid.Row="3"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0 0 0 8" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="CornerRadius" Value="0" />
                    <Setter Property="Template">
                        <ControlTemplate>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}" />
                        </ControlTemplate>
                    </Setter>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListBox.Styles>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource SideBarBackground}" Padding="24">
                        <Grid ColumnDefinitions="4*, 1.5*, *, 0.75*" Margin="0 0 24 0" ColumnSpacing="8">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Classes="ModListEntry" Text="{Binding Name}" FontSize="18"
                                           TextTrimming="CharacterEllipsis" FontWeight="Bold"
                                           FontFamily="{DynamicResource SpaceGrotesk}">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding Name}" FontSize="14"
                                                   FontFamily="{DynamicResource SpaceGrotesk}" />
                                    </ToolTip.Tip>
                                </TextBlock>
                                <TextBlock Classes="ModListEntry" Text="{Binding Abstract}" FontSize="12"
                                           TextTrimming="CharacterEllipsis" FontWeight="Regular"
                                           Foreground="{DynamicResource SecondaryText}"
                                           FontFamily="{DynamicResource Inter}">
                                    <ToolTip.Tip>
                                        <TextBlock Text="{Binding Abstract}" FontSize="14"
                                                   FontFamily="{DynamicResource Inter}" />
                                    </ToolTip.Tip>
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Classes="ModListEntry" Text="{Binding AuthorsDisplay}"
                                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                       FontFamily="{DynamicResource SpaceGrotesk}">
                                <ToolTip.Tip>
                                    <TextBlock Text="{Binding AuthorsDisplay}" FontSize="14"
                                               FontFamily="{DynamicResource SpaceGrotesk}" />
                                </ToolTip.Tip>
                            </TextBlock>
                            <ComboBox Grid.Column="2" ItemsSource="{Binding Versions}" VerticalAlignment="Center"
                                      CornerRadius="0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Version}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <TextBlock Grid.Column="3" Classes="ModListEntry"
                                       Text="{Binding LatestVersion.LastUpdatedHumanized}" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryText}">
                                <ToolTip.Tip>
                                    <TextBlock Text="{Binding LatestVersion.ReleaseDate}" FontSize="14"
                                               FontFamily="{DynamicResource Inter}" />
                                </ToolTip.Tip>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>