<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1144" d:DesignHeight="720"
             xmlns:vm="clr-namespace:KMRLauncherMvvm.ViewModels"
             x:DataType="vm:SettingsPageViewModel"
             x:Class="KMRLauncherMvvm.Views.SettingsPageView"
             Background="{DynamicResource PrimaryBackground}"
             Foreground="{DynamicResource PrimaryText}">
    
    <Design.DataContext>
        <vm:SettingsPageViewModel/>
    </Design.DataContext>
    
    <StackPanel Margin="32 16" Spacing="32">
        <TextBlock Text="GLOBAL SETTINGS" 
                   FontFamily="{DynamicResource SpaceMonoBold}"
                   FontSize="48"
                   LetterSpacing="1"
                   Foreground="{DynamicResource PrimaryText}"/>
        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="32">
            <StackPanel Grid.Column="0" Spacing="10">
                <Button Classes="SettingsNav Active">
                    <TextBlock Text="GENERAL" Classes="SettingsNav Active" />
                </Button>
                <Button Classes="SettingsNav">
                    <TextBlock Text="DOWNLOADS" Classes="SettingsNav" />
                </Button>
                <Button Classes="SettingsNav">
                    <TextBlock Text="ADVANCED" Classes="SettingsNav" />
                </Button>
            </StackPanel>
            <StackPanel Grid.Column="1" Spacing="16">
                <Grid ColumnDefinitions="*, Auto" Margin="0">
                    <Border Grid.Column="0" Background="{DynamicResource SecondaryText}" Height="2" HorizontalAlignment="Stretch" Margin="0,10,16,10" Opacity="0.4"/>
                    <TextBlock Grid.Column="1" Text="GENERAL CONFIGURATION" FontFamily="{DynamicResource SpaceMonoBold}" FontSize="18" LetterSpacing="3" Foreground="{DynamicResource SecondaryText}" />
                </Grid>
                <TextBox AcceptsReturn="False" MaxLines="1" Text="{Binding ZipPath}"/>
                <Button Classes="Primary" HorizontalAlignment="Right"
                        Command="{Binding BrowseFolderCommand}"
                        CommandParameter="{Binding $parent[UserControl]}">Open File</Button>
                <ComboBox ItemsSource="{Binding AllKspVersions}" HorizontalAlignment="Right"
                          SelectedValue="{Binding ZipVersion}" Width="100">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Classes="Primary" HorizontalAlignment="Right"
                        Command="{Binding AddKspZipCommand}">Add KSP Zip</Button>
                <ListBox ItemsSource="{Binding AppSettings.KspZips}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="5*, *, auto" Margin="24 8">
                                <TextBlock Grid.Column="0" Text="{Binding Path}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Version}" VerticalAlignment="Center"/>
                                <Button Grid.Column="2" Classes="Primary"
                                        Command="{Binding $parent[UserControl].((vm:SettingsPageViewModel)DataContext).RemoveKspZipCommand}"
                                        CommandParameter="{Binding}">REMOVE</Button>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Grid>
    </StackPanel>
    
</UserControl>
