<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
             Background="#1F1F20"
             Foreground="{DynamicResource PrimaryText}"
             Width="700" Height="600"
             x:Class="KMRLauncherMvvm.Views.InstallMods.InstallModsSelectVersionStep">
    
    <UserControl.Styles>
        <Style Selector="ComboBox">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        
        <Style Selector="ComboBox:pointerover /template/ Border">
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryRed}" />
            <Setter Property="Background" Value="Black" />
        </Style>
        
        <Style Selector="ComboBox:focus /template/ Border">
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Black" />
        </Style>
        
        <Style Selector="ComboBox:pressed /template/ Border">
            <Setter Property="Background" Value="Black" />
        </Style>
    </UserControl.Styles>
    
    <StackPanel Spacing="32">
        <StackPanel Spacing="4">
            <TextBlock Text="INSTALL MODS" FontSize="30" FontFamily="{DynamicResource SpaceMonoBold}" 
                       LetterSpacing="1.5" HorizontalAlignment="Left"/>
            <Grid ColumnDefinitions="* * * *" ColumnSpacing="8">
                <Rectangle Grid.Column="0" Height="4" Fill="{DynamicResource PrimaryRed}"/>
                <Rectangle Grid.Column="1" Height="4" Fill="{DynamicResource PrimaryBackground}"/>
                <Rectangle Grid.Column="2" Height="4" Fill="{DynamicResource PrimaryBackground}"/>
                <Rectangle Grid.Column="3" Height="4" Fill="{DynamicResource PrimaryBackground}"/>
            </Grid>
        </StackPanel>
        <StackPanel Spacing="8">
            <TextBlock Text="TARGET INSTANCE" LetterSpacing="1" Foreground="{DynamicResource SecondaryText}"
                       FontFamily="{DynamicResource SpaceMonoBold}" FontSize="12"/>
            <ComboBox Background="Black" HorizontalAlignment="Stretch" Height="48">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="Test" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
        <StackPanel Spacing="8">
            <TextBlock Text="MOD VERSION" LetterSpacing="1" Foreground="{DynamicResource SecondaryText}"
                       FontFamily="{DynamicResource SpaceMonoBold}" FontSize="12"/>
            <ComboBox Background="Black" HorizontalAlignment="Stretch" Height="48">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="Test" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>
    </StackPanel>
</UserControl>
