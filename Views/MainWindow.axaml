<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KMRLauncherMvvm.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="800"
        Width="1400" Height="800"
        x:Class="KMRLauncherMvvm.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Images/logoSmall.png"
        Title="KMR Launcher">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid Background="{DynamicResource SideBarBackground}" ColumnDefinitions="228, *">
        <Border Background="{DynamicResource SideBarBackground}">
            <Grid RowDefinitions="*, Auto">
                <StackPanel Spacing="10">
                    <Image Source="/Assets/Images/logo-dark.png" Margin="20 10"/>
                    <Button Classes="SideBarButton" Command="{Binding GoToHomeCommand}">
                        <Border Classes.Active="{Binding HomePageIsActive}" Classes="SideBarBorder">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Label Classes.Active="{Binding HomePageIsActive}" Classes="iconBold SideBarIcon" FontSize="24" Content="&#xE464;" />
                                <TextBlock Classes.Active="{Binding HomePageIsActive}" Classes="SideBarText" LetterSpacing="1" Text="Dashboard" />
                            </StackPanel>
                        </Border>
                    </Button>
                    <Button Classes="SideBarButton" Command="{Binding GoToDiscoverCommand}">
                        <Border Classes.Active="{Binding DiscoverPageIsActive}" Classes="SideBarBorder">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Label Classes.Active="{Binding DiscoverPageIsActive}" Classes="iconBold SideBarIcon" FontSize="24" Content="&#xE1C8;"/>
                                <TextBlock Classes.Active="{Binding DiscoverPageIsActive}" Classes="SideBarText" LetterSpacing="1" Text="Browse Mods" />
                            </StackPanel>
                        </Border>
                    </Button>
                    <Button Classes="SideBarButton" Command="{Binding GoToInstancesCommand}">
                        <Border Classes.Active="{Binding InstancesPageIsActive}" Classes="SideBarBorder">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Label Classes.Active="{Binding InstancesPageIsActive}" Classes="icon SideBarIcon" FontSize="24" Content="&#xE758;"/>
                                <TextBlock Classes.Active="{Binding InstancesPageIsActive}" Classes="SideBarText" LetterSpacing="1" Text="Instances" />
                            </StackPanel>
                        </Border>
                    </Button>
                </StackPanel>
                <Button Grid.Row="1" Classes="SideBarButton" Command="{Binding GoToSettingsCommand}">
                    <Border Classes.Active="{Binding SettingsPageIsActive}" Classes="SideBarBorder">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <Label Classes.Active="{Binding SettingsPageIsActive}" Classes="iconBold SideBarIcon" FontSize="24" Content="&#xE270;"/>
                            <TextBlock Classes.Active="{Binding SettingsPageIsActive}" Classes="SideBarText" LetterSpacing="1" Text="Settings" />
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>
        </Border>
        <Border Grid.Column="1" Background="{DynamicResource PrimaryBackground}" CornerRadius="0 0 0 0">
            <ContentControl Content="{Binding CurrentPage}" ></ContentControl>
        </Border>
    </Grid>
</Window>
